{
  "name": "@mergifyio/playwright",
  "version": "0.0.0",
  "description": "Playwright plugin for Mergify CI Insights",
  "license": "GPL-3.0-only",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./reporter": {
      "import": {
        "types": "./dist/reporter.d.ts",
        "default": "./dist/reporter.js"
      },
      "require": {
        "types": "./dist/reporter.d.cts",
        "default": "./dist/reporter.cjs"
      }
    },
    "./setup": {
      "import": {
        "types": "./dist/setup.d.ts",
        "default": "./dist/setup.js"
      },
      "require": {
        "types": "./dist/setup.d.cts",
        "default": "./dist/setup.cjs"
      }
    },
    "./teardown": {
      "import": {
        "types": "./dist/teardown.d.ts",
        "default": "./dist/teardown.js"
      },
      "require": {
        "types": "./dist/teardown.d.cts",
        "default": "./dist/teardown.cjs"
      }
    },
    "./fixture": {
      "import": {
        "types": "./dist/fixture.d.ts",
        "default": "./dist/fixture.js"
      },
      "require": {
        "types": "./dist/fixture.d.cts",
        "default": "./dist/fixture.cjs"
      }
    },
    "./config": {
      "import": {
        "types": "./dist/config.d.ts",
        "default": "./dist/config.js"
      },
      "require": {
        "types": "./dist/config.d.cts",
        "default": "./dist/config.cjs"
      }
    }
  },
  "files": ["dist"],
  "engines": {
    "node": "^20.0.0 || >=22.0.0"
  },
  "dependencies": {
    "@mergifyio/ci-core": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/core": "^1.30.0"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "devDependencies": {
    "@opentelemetry/sdk-trace-base": "^1.30.0",
    "@playwright/test": "^1.40.0",
    "vitest": "^4.1.4"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "keywords": ["playwright", "test", "flaky-tests", "testing", "ci"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mergifyio/mergify-ci-plugins.git",
    "directory": "packages/playwright"
  },
  "author": "Mergify <hello@mergify.com>"
}

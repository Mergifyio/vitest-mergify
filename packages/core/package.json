{
  "name": "@mergifyio/ci-core",
  "version": "0.0.0",
  "description": "Shared core for Mergify CI test framework plugins",
  "license": "GPL-3.0-only",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^20.0.0 || >=22.0.0"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/core": "^2.7.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.215.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-trace-base": "^2.6.1"
  },
  "devDependencies": {
    "vitest": "^4.1.4"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mergifyio/mergify-ci-plugins.git",
    "directory": "packages/core"
  },
  "author": "Mergify <hello@mergify.com>"
}

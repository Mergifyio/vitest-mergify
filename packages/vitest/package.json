{
  "name": "@mergifyio/vitest",
  "version": "0.0.0",
  "description": "Vitest reporter for Mergify CI Insights",
  "license": "GPL-3.0-only",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./runner": {
      "import": {
        "types": "./dist/runner.d.ts",
        "default": "./dist/runner.js"
      },
      "require": {
        "types": "./dist/runner.d.cts",
        "default": "./dist/runner.cjs"
      }
    }
  },
  "files": ["dist"],
  "engines": {
    "node": "^20.0.0 || >=22.0.0"
  },
  "dependencies": {
    "@mergifyio/ci-core": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/core": "^2.6.1"
  },
  "peerDependencies": {
    "vitest": ">=3.0.0"
  },
  "devDependencies": {
    "@opentelemetry/sdk-trace-base": "^1.30.0",
    "@vitest/runner": "^4.1.4",
    "vitest": "^4.1.4"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "keywords": ["vitest", "test", "flaky-tests", "testing", "ci"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mergifyio/mergify-ci-plugins.git",
    "directory": "packages/vitest"
  },
  "author": "Mergify <hello@mergify.com>"
}
